reg_iv <- ivreg(y ~ x | z, data = Data)
beta_iv[s, ] <- coef(reg_iv)
}
# Results
head(beta_lm)
head(beta_iv)
# Average estimates
colMeans(beta_lm)
colMeans(beta_iv)
